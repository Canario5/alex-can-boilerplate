{
  "name": "alex-can-boilerplate",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": "^24.0.0"
  },
  "scripts": {
    "dev:up": "docker compose up dev",
    "dev:shell": "docker compose exec --user vscode dev sh",
    "dev:rebuild": "pnpm run dev:down && docker compose build dev --no-cache",
    "dev:logs": "docker compose logs -f dev",
    "dev:down": "docker compose rm -fsv dev",
    "prod:up": "docker compose up -d prod",
    "prod:rebuild": "pnpm run prod:down && docker compose build prod --no-cache",
    "prod:down": "docker compose rm -fsv prod",
    "docker:stop": "docker compose down",
    "trivy:code": "echo 'Scanning source code for secrets and misconfigurations...' && docker compose run --rm dev trivy --config trivy.yaml fs .",
    "trivy:image": "echo 'Scanning the Docker image for secrets and misconfigurations...' && docker compose run --rm dev trivy --config trivy.yaml image alex-can-boilerplate-prod",
    "trivy:vuln": "echo 'Scanning for vulnerabilities...' && docker compose run --rm dev trivy --config trivy.yaml fs . --scanners vuln --include-dev-deps",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint:check": "biome check .",
    "lint:apply": "biome check --write .",
    "lint:staged": "echo 'Running Biome linter...'; biome check --write --no-errors-on-unmatched",
    "commitlint:check": "commitlint --edit",
    "check:types": "echo 'Checking TypeScript types...'; tsc --noEmit",
    "knip:check": "echo 'Running Knip check...' && knip",
    "knip:apply": "echo 'Running Knip auto-fix...' && knip --fix --format",
    "knip:prod": "echo 'Running Knip production check...' && knip --production",
    "depcruise:check": "depcruise .",
    "depcruise:report": "depcruise . -T html -f reports/depcruiser/depcruise.html && depcruise . -T d2 -f reports/depcruiser/depcruise.d2 && d2 reports/depcruiser/depcruise.d2 reports/depcruiser/depcruise.svg",
    "validate": "pnpm run knip:prod && pnpm run depcruise:check && pnpm run check:types && pnpm run lint:check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:unit:coverage": "vitest run --project unit --coverage",
    "test:unit:watch": "vitest --project unit",
    "test:component": "vitest run --project component",
    "test:component:coverage": "vitest run --project component --coverage",
    "test:component:watch": "vitest --project component",
    "test:integration": "vitest run --project integration",
    "test:integration:coverage": "vitest run --project integration --coverage",
    "test:integration:watch": "vitest --project integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@commitlint/types": "21.0.1",
    "@playwright/test": "1.60.0",
    "@types/jest-axe": "3.5.9",
    "@types/node": "24.12.4",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/browser-playwright": "4.1.7",
    "@vitest/coverage-v8": "4.1.7",
    "dependency-cruiser": "17.4.0",
    "jest-axe": "10.0.0",
    "knip": "6.14.2",
    "lefthook": "2.1.8",
    "playwright": "1.60.0",
    "typescript": "5.9.3",
    "vite": "8.0.16",
    "vitest": "4.1.7",
    "vitest-browser-react": "2.2.0"
  }
}
